import { useState, useMemo, useEffect } from 'antigravity';
import { 
  signInWithPopup, 
  signOut, 
  onAuthStateChanged,
  signInWithEmailAndPassword,
  createUserWithEmailAndPassword,
  signInWithPhoneNumber,
  RecaptchaVerifier
} from "firebase/auth";
import { doc, onSnapshot, setDoc } from "firebase/firestore";
import { auth, db, googleProvider, isFirebaseEnabled } from "./firebase";
import Header from './components/Header';
import Calendar from './components/Calendar';
import Analytics from './components/Analytics';
import Checklist from './components/Checklist';
import { useGamifiedState } from './utils/useGamifiedState';
import { computeLevelFromXP } from './utils/gamificationEngine';

export default function App() {
  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split('T')[0]);
  const [currentMonth, setCurrentMonth] = useState(new Date());
  const [user, setUser] = useState(null);
  const [isAuthLoading, setIsAuthLoading] = useState(isFirebaseEnabled);
  const [dismissAuthCard, setDismissAuthCard] = useState(false);
  const [authError, setAuthError] = useState(null);

  // Secure Gateway Tab Matrix States
  const [authTab, setAuthTab] = useState('email'); // 'email' | 'phone'
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [isSignUp, setIsSignUp] = useState(false);
  const [phoneNumber, setPhoneNumber] = useState('');
  const [otpCode, setOtpCode] = useState('');
  const [otpSent, setOtpSent] = useState(false);

  // Focus Chamber state models
  const [isFocusActive, setIsFocusActive] = useState(false);
  const [focusTimeLeft, setFocusTimeLeft] = useState(1500); // 25 minutes in seconds
  const [focusBreached, setFocusBreached] = useState(false);

  // Dynamic dashboard themes: 'emerald', 'purple', 'blue'
  const [theme, setTheme] = useState(() => {
    const saved = localStorage.getItem('ag_theme');
    return saved || 'emerald';
  });
  
  const [trackerData, setTrackerData] = useState(() => {
    const saved = localStorage.getItem('ag_tracker_data');
    return saved ? JSON.parse(saved) : {};
  });

  const [customHabits, setCustomHabits] = useState(() => {
    const saved = localStorage.getItem('ag_global_habits');
    return saved ? JSON.parse(saved) : [];
  });

  // RPG telemetry bonus/penalty offset (chest claims & focus breaches)
  const [rpgBonusXp, setRpgBonusXp] = useState(() => {
    const saved = localStorage.getItem('ag_rpg_bonus_xp');
    return saved ? parseInt(saved, 10) : 0;
  });

  const [claimedMilestones, setClaimedMilestones] = useState(() => {
    const saved = localStorage.getItem('ag_claimed_milestones');
    return saved ? JSON.parse(saved) : [];
  });

  const [unclaimedChests, setUnclaimedChests] = useState(() => {
    const saved = localStorage.getItem('ag_unclaimed_chests');
    return saved ? JSON.parse(saved) : [];
  });

  // Keep LocalStorage fallback cache updated
  useEffect(() => {
    localStorage.setItem('ag_tracker_data', JSON.stringify(trackerData));
  }, [trackerData]);

  useEffect(() => {
    localStorage.setItem('ag_global_habits', JSON.stringify(customHabits));
  }, [customHabits]);

  useEffect(() => {
    localStorage.setItem('ag_theme', theme);
  }, [theme]);

  useEffect(() => {
    localStorage.setItem('ag_rpg_bonus_xp', rpgBonusXp.toString());
  }, [rpgBonusXp]);

  useEffect(() => {
    localStorage.setItem('ag_claimed_milestones', JSON.stringify(claimedMilestones));
  }, [claimedMilestones]);

  useEffect(() => {
    localStorage.setItem('ag_unclaimed_chests', JSON.stringify(unclaimedChests));
  }, [unclaimedChests]);

  // Auth State Listener
  useEffect(() => {
    if (!isFirebaseEnabled) return;
    const unsubscribe = onAuthStateChanged(auth, (currentUser) => {
      setUser(currentUser);
      setIsAuthLoading(false);
    });
    return () => unsubscribe();
  }, []);

  // Firestore Snapshot Sync Listener (WebSockets streaming under users/{uid})
  useEffect(() => {
    if (!isFirebaseEnabled || !user) return;

    const userDocRef = doc(db, "users", user.uid);
    const unsubscribe = onSnapshot(userDocRef, (docSnap) => {
      if (docSnap.exists()) {
        const data = docSnap.data();
        if (data.trackerData) setTrackerData(data.trackerData);
        if (data.customHabits) setCustomHabits(data.customHabits);
        if (data.theme) setTheme(data.theme);
        if (data.rpgBonusXp !== undefined) setRpgBonusXp(data.rpgBonusXp);
        if (data.claimedMilestones) setClaimedMilestones(data.claimedMilestones);
        if (data.unclaimedChests) setUnclaimedChests(data.unclaimedChests);
      } else {
        // Doc doesn't exist, initialize Firestore with current local state
        setDoc(userDocRef, {
          trackerData: trackerData,
          customHabits: customHabits,
          theme: theme,
          rpgBonusXp: rpgBonusXp,
          claimedMilestones: claimedMilestones,
          unclaimedChests: unclaimedChests
        });
      }
    }, (err) => {
      console.error("Firestore snapshot error:", err);
    });

    return () => unsubscribe();
  }, [user]);

  const allHabits = useMemo(() => customHabits, [customHabits]);
  const todayStr = useMemo(() => new Date().toISOString().split('T')[0], []);

  // Compute base RPG parameters via gamification state hook
  const derivedTelemetry = useGamifiedState(trackerData, allHabits);

  // Derived RPG Telemetry State combining completions and database bonus offsets
  const characterStats = useMemo(() => {
    const finalXp = Math.max(0, derivedTelemetry.totalXP + rpgBonusXp);
    const levelInfo = computeLevelFromXP(finalXp);
    
    let title = 'Wandering Novice';
    let rankGlow = 'wandering-novice-glow';
    if (levelInfo.level >= 26) {
      title = 'Algorithm Sovereign';
      rankGlow = 'algorithm-sovereign-glow';
    } else if (levelInfo.level >= 13) {
      title = 'Shadow Cyber-Monk';
      rankGlow = 'shadow-cybermonk-glow';
    } else if (levelInfo.level >= 6) {
      title = 'Code Vanguard';
      rankGlow = 'code-vanguard-glow';
    }

    return { 
      level: levelInfo.level, 
      currentXp: levelInfo.xpInCurrentLevel, 
      xpNeeded: 100, 
      title, 
      rankGlow,
      totalXp: finalXp
    };
  }, [derivedTelemetry.totalXP, rpgBonusXp]);

  // Dynamic 7-day Streak Reward Checker
  useEffect(() => {
    const newChests = [];
    const newClaimed = [...claimedMilestones];
    let changed = false;

    allHabits.forEach(habit => {
      const completedDates = Object.keys(trackerData).filter(
        date => trackerData[date] && trackerData[date][habit.id]
      ).sort();

      if (completedDates.length === 0) return;

      let currentStreak = 0;
      let checkDate = new Date(todayStr + 'T00:00:00');
      
      const hasToday = completedDates.includes(todayStr);
      
      const yesterday = new Date(checkDate);
      yesterday.setDate(yesterday.getDate() - 1);
      const yesterdayStr = yesterday.toISOString().split('T')[0];
      const hasYesterday = completedDates.includes(yesterdayStr);

      if (hasToday || hasYesterday) {
        let currentDate = hasToday ? checkDate : yesterday;
        while (true) {
          const dateStr = currentDate.toISOString().split('T')[0];
          if (completedDates.includes(dateStr)) {
            currentStreak++;
            currentDate.setDate(currentDate.getDate() - 1);
          } else {
            break;
          }
        }
      }

      if (currentStreak >= 7) {
        const streakLevel = Math.floor(currentStreak / 7) * 7;
        const milestoneKey = `${habit.id}_${streakLevel}`;
        if (!newClaimed.includes(milestoneKey)) {
          newClaimed.push(milestoneKey);
          newChests.push({
            id: `chest_${Date.now()}_${habit.id}_${streakLevel}`,
            habitLabel: habit.label,
            streak: streakLevel
          });
          changed = true;
        }
      }
    });

    if (changed) {
      setUnclaimedChests(prev => [...prev, ...newChests]);
      setClaimedMilestones(newClaimed);

      if (isFirebaseEnabled && user) {
        const userDocRef = doc(db, "users", user.uid);
        setDoc(userDocRef, {
          unclaimedChests: [...unclaimedChests, ...newChests],
          claimedMilestones: newClaimed
        }, { merge: true }).catch(err => console.error("Milestone write error:", err));
      }
    }
  }, [trackerData, allHabits, todayStr]);

  // Focus Chamber Timer Countdown Loop
  useEffect(() => {
    if (!isFocusActive) return;
    if (focusTimeLeft <= 0) {
      setIsFocusActive(false);
      if (document.fullscreenElement) {
        document.exitFullscreen().catch(() => {});
      }
      setRpgBonusXp(prev => prev + 50); // Award XP on success
      alert("Focus Session Complete! Core Telemetry rewarded with +50 XP!");
      return;
    }

    const timer = setInterval(() => {
      setFocusTimeLeft(prev => prev - 1);
    }, 1000);

    return () => clearInterval(timer);
  }, [isFocusActive, focusTimeLeft]);

  // Monitor Page Visibility leaks in Focus Chamber
  useEffect(() => {
    if (!isFocusActive) return;

    const handleVisibilityChange = () => {
      if (document.hidden) {
        setIsFocusActive(false);
        if (document.fullscreenElement) {
          document.exitFullscreen().catch(() => {});
        }
        // Deduct XP penalty
        setRpgBonusXp(prev => Math.max(0, prev - 25));
        setFocusBreached(true);
        
        // Write penalty drop directly to Firestore if logged in
        if (isFirebaseEnabled && user) {
          const userDocRef = doc(db, "users", user.uid);
          setDoc(userDocRef, { rpgBonusXp: Math.max(0, rpgBonusXp - 25) }, { merge: true })
            .catch(err => console.error("Penalties save error:", err));
        }
      }
    };

    document.addEventListener("visibilitychange", handleVisibilityChange);
    return () => {
      document.removeEventListener("visibilitychange", handleVisibilityChange);
    };
  }, [isFocusActive, rpgBonusXp, user]);

  const enterFocusChamber = () => {
    setFocusTimeLeft(1500); // 25 minutes
    setFocusBreached(false);
    setIsFocusActive(true);
    
    if (document.documentElement.requestFullscreen) {
      document.documentElement.requestFullscreen().catch((err) => {
        console.warn("Fullscreen request rejected:", err);
      });
    }
  };

  const exitFocusChamberEarly = () => {
    setIsFocusActive(false);
    if (document.fullscreenElement) {
      document.exitFullscreen().catch(() => {});
    }
    setRpgBonusXp(prev => Math.max(0, prev - 25));
    setFocusBreached(true);
    
    if (isFirebaseEnabled && user) {
      const userDocRef = doc(db, "users", user.uid);
      setDoc(userDocRef, { rpgBonusXp: Math.max(0, rpgBonusXp - 25) }, { merge: true })
        .catch(err => console.error("Penalties save error:", err));
    }
  };

  const toggleHabit = async (habitId) => {
    const updatedTracker = { ...trackerData };
    const dayData = updatedTracker[selectedDate] || {};
    const willBeCompleted = !dayData[habitId];
    updatedTracker[selectedDate] = { ...dayData, [habitId]: willBeCompleted };
    
    setTrackerData(updatedTracker);
    
    if (isFirebaseEnabled && user) {
      try {
        const userDocRef = doc(db, "users", user.uid);
        await setDoc(userDocRef, { trackerData: updatedTracker }, { merge: true });
      } catch (err) {
        console.error("Firestore write error:", err);
      }
    }
  };

  const addCustomHabit = async (label, tag) => {
    if (!label.trim()) return;
    const newId = `custom_${Date.now()}`;
    const newHabit = { id: newId, label: label.trim(), tag: tag || 'Mind' };
    const updatedHabits = [...customHabits, newHabit];
    
    setCustomHabits(updatedHabits);
    
    if (isFirebaseEnabled && user) {
      try {
        const userDocRef = doc(db, "users", user.uid);
        await setDoc(userDocRef, { customHabits: updatedHabits }, { merge: true });
      } catch (err) {
        console.error("Firestore write error:", err);
      }
    }
  };

  const removeCustomHabit = async (id) => {
    const updatedHabits = customHabits.filter(h => h.id !== id);
    const updatedTracker = { ...trackerData };
    
    Object.keys(updatedTracker).forEach(date => {
      if (updatedTracker[date]) {
        delete updatedTracker[date][id];
      }
    });
    
    setCustomHabits(updatedHabits);
    setTrackerData(updatedTracker);
    
    if (isFirebaseEnabled && user) {
      try {
        const userDocRef = doc(db, "users", user.uid);
        await setDoc(userDocRef, { 
          customHabits: updatedHabits,
          trackerData: updatedTracker 
        }, { merge: true });
      } catch (err) {
        console.error("Firestore write error:", err);
      }
    }
  };

  const saveJournal = async (text) => {
    const updatedTracker = { ...trackerData };
    const dayData = updatedTracker[selectedDate] || {};
    updatedTracker[selectedDate] = { ...dayData, _journal: text };
    
    setTrackerData(updatedTracker);
    
    if (isFirebaseEnabled && user) {
      try {
        const userDocRef = doc(db, "users", user.uid);
        await setDoc(userDocRef, { trackerData: updatedTracker }, { merge: true });
      } catch (err) {
        console.error("Firestore write error:", err);
      }
    }
  };

  const selectTheme = async (newTheme) => {
    setTheme(newTheme);
    if (isFirebaseEnabled && user) {
      try {
        const userDocRef = doc(db, "users", user.uid);
        await setDoc(userDocRef, { theme: newTheme }, { merge: true });
      } catch (err) {
        console.error("Firestore write error:", err);
      }
    }
  };

  const openChest = async (chestId) => {
    const updatedChests = unclaimedChests.filter(c => c.id !== chestId);
    const newBonusXp = rpgBonusXp + 100; // Award +100 XP
    
    setUnclaimedChests(updatedChests);
    setRpgBonusXp(newBonusXp);
    
    if (isFirebaseEnabled && user) {
      try {
        const userDocRef = doc(db, "users", user.uid);
        await setDoc(userDocRef, { 
          unclaimedChests: updatedChests,
          rpgBonusXp: newBonusXp
        }, { merge: true });
      } catch (err) {
        console.error("Firestore write error:", err);
      }
    }
  };

  const handleEmailAuth = async (e) => {
    e.preventDefault();
    if (!email.trim() || !password.trim()) {
      setAuthError("Email and password fields are required.");
      return;
    }
    
    if (!isFirebaseEnabled) {
      setUser({
        uid: "mock_email_" + btoa(email).substring(0, 8),
        displayName: email.split('@')[0],
        email: email
      });
      setDismissAuthCard(true);
      setAuthError("Firebase is disabled. Running in Mock Developer Sandbox Mode.");
      return;
    }

    try {
      setAuthError(null);
      if (isSignUp) {
        await createUserWithEmailAndPassword(auth, email, password);
      } else {
        await signInWithEmailAndPassword(auth, email, password);
      }
      setDismissAuthCard(true);
    } catch (err) {
      console.error("Email auth error:", err);
      setAuthError(err.message || "Email authentication failed.");
    }
  };

  const setupRecaptcha = () => {
    if (!window.recaptchaVerifier) {
      window.recaptchaVerifier = new RecaptchaVerifier(auth, 'recaptcha-container', {
        'size': 'invisible',
        'callback': (response) => {
          // reCAPTCHA solved
        }
      });
    }
  };

  const handleSendOtp = async (e) => {
    e.preventDefault();
    if (!phoneNumber.trim()) {
      setAuthError("Phone number is required.");
      return;
    }

    if (!isFirebaseEnabled) {
      setOtpSent(true);
      setAuthError("Firebase is disabled. Mock OTP code '123456' sent to " + phoneNumber);
      return;
    }

    try {
      setAuthError(null);
      setupRecaptcha();
      const appVerifier = window.recaptchaVerifier;
      const confirmationResult = await signInWithPhoneNumber(auth, phoneNumber, appVerifier);
      window.confirmationResult = confirmationResult;
      setOtpSent(true);
    } catch (err) {
      console.error("Phone sign in error:", err);
      setAuthError(err.message || "Failed to send SMS OTP.");
      if (window.recaptchaVerifier) {
        window.recaptchaVerifier.clear();
        window.recaptchaVerifier = null;
      }
    }
  };

  const handleVerifyOtp = async (e) => {
    e.preventDefault();
    if (!otpCode.trim()) {
      setAuthError("Verification code is required.");
      return;
    }

    if (!isFirebaseEnabled) {
      if (otpCode === "123456") {
        setUser({
          uid: "mock_phone_" + btoa(phoneNumber).substring(0, 8),
          displayName: "Phone Warrior " + phoneNumber.slice(-4),
          phoneNumber: phoneNumber
        });
        setDismissAuthCard(true);
        setAuthError("Successfully signed in with mock OTP.");
      } else {
        setAuthError("Invalid verification code. Use '123456' for mock testing.");
      }
      return;
    }

    try {
      setAuthError(null);
      const confirmationResult = window.confirmationResult;
      if (!confirmationResult) {
        setAuthError("No active SMS transaction found. Please request a new OTP code.");
        return;
      }
      const result = await confirmationResult.confirm(otpCode);
      setUser(result.user);
      setDismissAuthCard(true);
    } catch (err) {
      console.error("OTP Verification error:", err);
      setAuthError(err.message || "Invalid verification code.");
    }
  };

  const loginWithGoogle = async () => {
    if (!isFirebaseEnabled) {
      setUser({
        uid: "mock_warrior_1337",
        displayName: "Beta Sandbox Warrior",
        photoURL: null
      });
      setDismissAuthCard(true);
      setAuthError("Firebase VITE_FIREBASE_API_KEY is not configured in .env.local. Running in Mock Developer Sandbox Mode.");
      return;
    }
    try {
      setAuthError(null);
      await signInWithPopup(auth, googleProvider);
    } catch (err) {
      console.error("Google Auth Sign-In failed:", err);
      let message = "An error occurred during authentication.";
      if (err.code === "auth/unauthorized-domain") {
        message = "Domain Restriction: This domain is not authorized in the Firebase console for Google Sign-In.";
      } else if (err.code === "auth/popup-blocked") {
        message = "Popup Blocked: The authentication popup was blocked by your browser. Please allow popups for this site.";
      } else if (err.code === "auth/popup-closed-by-user") {
        message = "Popup Closed: The authentication window was closed before completing sign-in.";
      } else {
        message = err.message || message;
      }
      setAuthError(message);
    }
  };

  const logoutUser = async () => {
    if (!isFirebaseEnabled) {
      setUser(null);
      return;
    }
    try {
      await signOut(auth);
      const localTracker = localStorage.getItem('ag_tracker_data');
      const localHabits = localStorage.getItem('ag_global_habits');
      const localBonus = localStorage.getItem('ag_rpg_bonus_xp');
      setTrackerData(localTracker ? JSON.parse(localTracker) : {});
      setCustomHabits(localHabits ? JSON.parse(localHabits) : []);
      setRpgBonusXp(localBonus ? parseInt(localBonus, 10) : 0);
      setUnclaimedChests([]);
    } catch (err) {
      console.error("Google Auth Sign-Out failed:", err);
    }
  };

  const changeMonth = (direction) => {
    setCurrentMonth(prev => {
      const newMonth = new Date(prev);
      newMonth.setMonth(newMonth.getMonth() + direction);
      return newMonth;
    });
  };

  const calendarDays = useMemo(() => {
    const year = currentMonth.getFullYear();
    const month = currentMonth.getMonth();
    const days = new Array(new Date(year, month, 1).getDay()).fill(null);
    const totalDays = new Date(year, month + 1, 0).getDate();
    
    for (let i = 1; i <= totalDays; i++) {
      const dayStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      days.push({ dayNumber: i, dateStr: dayStr });
    }
    return days;
  }, [currentMonth]);

  const chartData = useMemo(() => {
    const data = [];
    for (let i = 29; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      const dateStr = d.toISOString().split('T')[0];
      const dayData = trackerData[dateStr] || {};
      
      const totalChecksPossible = allHabits.length;
      const checksCompleted = allHabits.filter(h => dayData[h.id] === true).length;
      const percentage = totalChecksPossible > 0 ? Math.round((checksCompleted / totalChecksPossible) * 100) : 0;

      data.push({
        date: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
        Completion: percentage
      });
    }
    return data;
  }, [trackerData, allHabits]);

  if (isAuthLoading) {
    return (
      <div className="min-h-screen text-zinc-100 flex items-center justify-center p-4 bg-zinc-950 selection:bg-emerald-500/10 selection:text-emerald-400">
        <div className="flex flex-col items-center gap-3">
          <div className="w-8 h-8 rounded-full border-2 border-emerald-500/20 border-t-emerald-400 animate-spin"></div>
          <span className="text-xs font-semibold text-zinc-500 tracking-wider uppercase">
            Establishing Interlock Sync...
          </span>
        </div>
      </div>
    );
  }

  if (isFirebaseEnabled && !user && !dismissAuthCard) {
    return (
      <div className="min-h-screen text-zinc-100 flex items-center justify-center p-4 antialiased bg-zinc-950 selection:bg-emerald-500/10 selection:text-emerald-400">
        
        {/* Invisible Recaptcha Container required for Firebase SMS verification */}
        <div id="recaptcha-container"></div>

        <div className="relative max-w-md w-full bg-zinc-900/30 border border-zinc-800/80 rounded-3xl p-8 backdrop-blur-md shadow-2xl text-center space-y-6 overflow-hidden">
          <div className="absolute -top-24 -left-24 w-48 h-48 rounded-full bg-emerald-500/10 blur-3xl"></div>
          <div className="absolute -bottom-24 -right-24 w-48 h-48 rounded-full bg-teal-500/10 blur-3xl"></div>

          <div className="space-y-2 relative z-10">
            <span className="text-4xl">⚡</span>
            <h1 className="text-3xl font-extrabold tracking-tight bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">
              HabitPulse
            </h1>
            <p className="text-xs text-zinc-400">
              Multi-Provider Secure Gateway
            </p>
          </div>

          {/* Secure Gateway Tab Matrix Selector */}
          <div className="grid grid-cols-2 gap-1.5 p-1 bg-zinc-950/60 border border-zinc-850 rounded-xl relative z-10">
            <button
              onClick={() => { setAuthTab('email'); setAuthError(null); }}
              className={`py-2 rounded-lg text-[10px] font-mono font-bold uppercase transition cursor-pointer ${
                authTab === 'email'
                  ? 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/20'
                  : 'text-zinc-500 hover:text-zinc-350 border border-transparent'
              }`}
            >
              ✉️ Email System
            </button>
            <button
              onClick={() => { setAuthTab('phone'); setAuthError(null); }}
              className={`py-2 rounded-lg text-[10px] font-mono font-bold uppercase transition cursor-pointer ${
                authTab === 'phone'
                  ? 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/20'
                  : 'text-zinc-500 hover:text-zinc-355 border border-transparent'
              }`}
            >
              📱 Phone OTP
            </button>
          </div>

          {/* Error Banner inside gateway */}
          {authError && (
            <div className="px-3.5 py-2.5 rounded-xl bg-red-500/5 border border-red-500/20 text-red-400 text-[10px] text-center font-mono select-none leading-relaxed z-10 relative">
              {authError}
            </div>
          )}

          {/* Active Tab Form Container */}
          <div className="space-y-4 relative z-10 text-left">
            {authTab === 'email' ? (
              <form onSubmit={handleEmailAuth} className="space-y-3.5">
                <div className="space-y-1">
                  <label className="text-[9px] font-mono font-bold text-zinc-500 uppercase tracking-wider">// Account Email</label>
                  <input
                    type="email"
                    required
                    value={email}
                    onChange={(e) => setEmail(e.target.value)}
                    placeholder="warrior@habitpulse.com"
                    className="w-full bg-zinc-950/60 border border-zinc-850 rounded-xl px-3.5 py-2.5 text-xs font-mono text-zinc-200 placeholder-zinc-700 focus:outline-none focus:border-zinc-700 transition"
                  />
                </div>
                <div className="space-y-1">
                  <label className="text-[9px] font-mono font-bold text-zinc-500 uppercase tracking-wider">// Cryptographic Password</label>
                  <input
                    type="password"
                    required
                    value={password}
                    onChange={(e) => setPassword(e.target.value)}
                    placeholder="••••••••••••"
                    className="w-full bg-zinc-950/60 border border-zinc-850 rounded-xl px-3.5 py-2.5 text-xs font-mono text-zinc-200 placeholder-zinc-700 focus:outline-none focus:border-zinc-700 transition"
                  />
                </div>

                <div className="flex items-center justify-between text-[10px] font-mono text-zinc-500 px-1 pt-1">
                  <span>{isSignUp ? "Already have an account?" : "Need a new account?"}</span>
                  <button
                    type="button"
                    onClick={() => { setIsSignUp(!isSignUp); setAuthError(null); }}
                    className="text-emerald-400 hover:text-emerald-300 transition cursor-pointer font-bold uppercase"
                  >
                    {isSignUp ? "Sign In" : "Register"}
                  </button>
                </div>

                <button
                  type="submit"
                  className="w-full py-3 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-black rounded-xl text-xs uppercase tracking-widest transition cursor-pointer active:scale-95 shadow-lg shadow-emerald-500/10 text-center font-mono mt-2"
                >
                  {isSignUp ? "Create Account" : "Access Console"}
                </button>
              </form>
            ) : (
              /* Mobile Phone OTP validation matrix */
              <div className="space-y-3.5">
                {!otpSent ? (
                  <form onSubmit={handleSendOtp} className="space-y-3.5">
                    <div className="space-y-1">
                      <label className="text-[9px] font-mono font-bold text-zinc-500 uppercase tracking-wider">// Telephone Coordinates</label>
                      <input
                        type="tel"
                        required
                        value={phoneNumber}
                        onChange={(e) => setPhoneNumber(e.target.value)}
                        placeholder="+1 555 123 4567"
                        className="w-full bg-zinc-950/60 border border-zinc-850 rounded-xl px-3.5 py-2.5 text-xs font-mono text-zinc-200 placeholder-zinc-700 focus:outline-none focus:border-zinc-700 transition"
                      />
                      <span className="text-[8px] text-zinc-500 font-mono leading-relaxed block mt-1">
                        Use full international dial coordinates prefix (e.g. +1).
                      </span>
                    </div>

                    <button
                      type="submit"
                      className="w-full py-3 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-black rounded-xl text-xs uppercase tracking-widest transition cursor-pointer active:scale-95 shadow-lg shadow-emerald-500/10 text-center font-mono mt-2"
                    >
                      Send OTP Verification
                    </button>
                  </form>
                ) : (
                  /* Cryptographic 6-digit verification code input block */
                  <form onSubmit={handleVerifyOtp} className="space-y-3.5">
                    <div className="space-y-1">
                      <div className="flex justify-between items-center">
                        <label className="text-[9px] font-mono font-bold text-zinc-500 uppercase tracking-wider">// Verification Code</label>
                        <button
                          type="button"
                          onClick={() => { setOtpSent(false); setAuthError(null); }}
                          className="text-[9px] font-mono text-zinc-500 hover:text-zinc-350 cursor-pointer"
                        >
                          Change Number
                        </button>
                      </div>
                      <input
                        type="text"
                        required
                        maxLength={6}
                        value={otpCode}
                        onChange={(e) => setOtpCode(e.target.value)}
                        placeholder="123456"
                        className="w-full bg-zinc-950/60 border border-zinc-850 rounded-xl px-3.5 py-2.5 text-xs font-mono text-zinc-200 placeholder-zinc-700 focus:outline-none focus:border-zinc-700 transition text-center tracking-widest text-lg"
                      />
                      <span className="text-[8px] text-zinc-500 font-mono leading-relaxed block mt-1">
                        Enter the 6-digit SMS code dispatched to {phoneNumber}.
                      </span>
                    </div>

                    <button
                      type="submit"
                      className="w-full py-3 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-black rounded-xl text-xs uppercase tracking-widest transition cursor-pointer active:scale-95 shadow-lg shadow-emerald-500/10 text-center font-mono mt-2"
                    >
                      Verify Token credentials
                    </button>
                  </form>
                )}
              </div>
            )}
          </div>

          {/* Social Sep & Google Login */}
          <div className="relative z-10 space-y-4">
            <div className="relative flex items-center justify-center font-mono text-[9px] text-zinc-650 uppercase">
              <div className="absolute inset-x-0 h-px bg-zinc-800/50"></div>
              <span className="relative bg-zinc-900/40 px-3.5 z-10 font-black tracking-widest">// OR CONTROLLER</span>
            </div>

            <button
              onClick={loginWithGoogle}
              className="w-full py-3 px-4 rounded-xl border border-zinc-850 hover:border-zinc-750 bg-zinc-950/40 hover:bg-zinc-955/80 hover:bg-zinc-950/80 text-zinc-300 hover:text-zinc-100 text-xs transition cursor-pointer active:scale-95 font-mono uppercase tracking-wider flex items-center justify-center gap-2"
            >
              <svg className="w-4 h-4 fill-current text-zinc-400 group-hover:text-zinc-200" viewBox="0 0 24 24">
                <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-5.136 4.114-3.51 0-6.377-2.87-6.377-6.38s2.867-6.38 6.377-6.38c1.6 0 3.05.59 4.178 1.57l3.079-3.08C19.4 2.73 16.03 1.5 12.24 1.5 6.27 1.5 1.5 6.27 1.5 1.5 6.27 1.5 1.5 6.27 1.5 1.24s4.77 10.74 10.74 10.74c5.96 0 10.66-4.73 10.66-10.74 0-.64-.06-1.28-.18-1.9H12.24z"/>
              </svg>
              Sign In with Google
            </button>
          </div>

          <div className="pt-2 border-t border-zinc-800/60 relative z-10">
            <button
              onClick={() => setDismissAuthCard(true)}
              className="text-[10px] font-mono font-bold text-zinc-500 hover:text-zinc-300 transition cursor-pointer uppercase tracking-wider"
            >
              Continue Offline (Local Storage Cache)
            </button>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen text-zinc-100 p-4 md:p-12 antialiased selection:bg-emerald-500/10 selection:text-emerald-400">
      
      {/* HTML5 Fullscreen Focus Chamber Overlay */}
      {isFocusActive && (
        <div className="fixed inset-0 bg-black/95 flex flex-col items-center justify-center p-6 z-50 animate-fade-in font-mono">
          <div className="max-w-md w-full border border-red-500/30 bg-zinc-950 p-8 rounded-3xl text-center space-y-6 relative">
            <div className="absolute top-2 right-4 text-[9px] text-zinc-500 font-mono uppercase">
              // focus chamber active
            </div>
            <div className="text-4xl animate-pulse">🧘</div>
            <div className="space-y-1">
              <h2 className="text-lg font-bold text-red-500 tracking-widest uppercase">BOSS MODE</h2>
              <p className="text-[10px] text-zinc-500 leading-relaxed uppercase">
                PAGE VISIBILITY SENSORS ONLINE. AVOID SWITCHING WINDOWS OR FOCUS.
              </p>
            </div>
            
            <div className="text-6xl font-black text-zinc-100 font-mono tracking-wider tabular-nums py-4">
              {Math.floor(focusTimeLeft / 60)}:{String(focusTimeLeft % 60).padStart(2, '0')}
            </div>

            <div className="text-xs text-zinc-500 font-mono">
              Penalty on Early Exit: <span className="text-red-400 font-bold">-25 XP</span>
            </div>

            <button
              onClick={exitFocusChamberEarly}
              className="w-full py-2.5 px-4 text-[10px] font-bold text-zinc-400 hover:text-red-400 border border-zinc-800 hover:border-red-500/20 bg-zinc-900/40 rounded-xl transition cursor-pointer font-mono uppercase tracking-wider"
            >
              ABORT SENSE CYCLE
            </button>
          </div>
        </div>
      )}

      {/* Focus Breached Alert Modal */}
      {focusBreached && (
        <div className="fixed inset-0 bg-black/90 backdrop-blur-md flex items-center justify-center p-4 z-50 animate-fade-in">
          <div className="max-w-sm w-full bg-zinc-900 border border-red-500/30 rounded-3xl p-6 text-center space-y-4 shadow-2xl relative">
            <div className="w-12 h-12 rounded-full bg-red-500/10 text-red-400 border border-red-500/20 flex items-center justify-center mx-auto text-xl font-bold">
              🚨
            </div>
            <div className="space-y-1">
              <h2 className="text-base font-extrabold text-red-500 font-mono tracking-widest uppercase">
                CHAMBER BREACHED
              </h2>
              <p className="text-xs text-zinc-400 font-mono leading-relaxed">
                Focus sensors registered target redirection. Telemetry penalized:
              </p>
            </div>
            <div className="text-2xl font-black text-red-400 font-mono tracking-wide">
              -25 XP DOCKED
            </div>
            <button
              onClick={() => setFocusBreached(false)}
              className="w-full py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-mono font-bold rounded-xl text-[10px] uppercase tracking-wider transition cursor-pointer"
            >
              Recalibrate HUD
            </button>
          </div>
        </div>
      )}

      {authError && (
        <div className="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 z-50 animate-fade-in">
          <div className="bg-zinc-900 border border-zinc-800/80 rounded-3xl p-6 max-w-sm w-full space-y-4 shadow-2xl relative z-50 text-center">
            <div className="w-12 h-12 rounded-full bg-red-500/10 text-red-400 border border-red-500/20 flex items-center justify-center mx-auto text-xl font-bold">
              ⚠️
            </div>
            <div className="space-y-1">
              <h2 className="text-base font-bold text-zinc-100">Sync Warning</h2>
              <p className="text-xs text-zinc-400 leading-relaxed">
                {authError}
              </p>
            </div>
            <button
              onClick={() => setAuthError(null)}
              className="w-full py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-semibold rounded-xl text-xs transition cursor-pointer"
            >
              Acknowledge & Continue Offline
            </button>
          </div>
        </div>
      )}

      <div className="max-w-6xl mx-auto">
        <Header 
          user={user} 
          loginWithGoogle={loginWithGoogle} 
          logoutUser={logoutUser} 
          isAuthLoading={isAuthLoading}
          characterStats={characterStats}
        />
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <div className="lg:col-span-2 space-y-8">
            <Calendar 
              allHabits={allHabits} 
              calendarDays={calendarDays} 
              changeMonth={changeMonth} 
              currentMonth={currentMonth} 
              selectedDate={selectedDate} 
              setSelectedDate={setSelectedDate} 
              trackerData={trackerData}
              todayStr={todayStr}
              theme={theme}
            />
            <Analytics chartData={chartData} theme={theme}/>
          </div>
          <div>
            <Checklist 
              addCustomHabit={addCustomHabit} 
              allHabits={allHabits} 
              removeCustomHabit={removeCustomHabit} 
              selectedDate={selectedDate} 
              selectedDayData={trackerData[selectedDate] || {}} 
              toggleHabit={toggleHabit}
              todayStr={todayStr}
              trackerData={trackerData}
              theme={theme}
              selectTheme={selectTheme}
              saveJournal={saveJournal}
              unclaimedChests={unclaimedChests}
              openChest={openChest}
              enterFocusChamber={enterFocusChamber}
            />
          </div>
        </div>
      </div>
    </div>
  );
}
