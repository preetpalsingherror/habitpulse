import { Plus, Trash2, Check } from 'lucide-react';

export default function Checklist({
  addCustomHabit,
  allHabits,
  customHabitInput,
  removeCustomHabit,
  selectedDate,
  selectedDayData,
  setCustomHabitInput,
  toggleHabit,
  todayStr,
}) {
  // Format selectedDate for display (e.g. "June 28, 2026")
  const dateObj = new Date(selectedDate + 'T00:00:00');
  const formattedDate = dateObj.toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'short',
    day: 'numeric',
  });

  const isFuture = selectedDate > todayStr;

  return (
    <div className="bg-zinc-900/30 border border-zinc-800/80 rounded-2xl p-6 backdrop-blur-md space-y-6">
      <div className="flex items-center justify-between gap-4">
        <div>
          <h2 className="text-sm font-semibold text-zinc-400 uppercase tracking-wider">Active Habits</h2>
          <p className="text-lg font-bold text-zinc-100 mt-1">{formattedDate}</p>
        </div>
        {isFuture && (
          <span className="px-2.5 py-1 text-[10px] font-bold uppercase rounded-md bg-zinc-950/60 text-zinc-500 border border-zinc-800/80 flex items-center gap-1 select-none">
            🔒 Locked
          </span>
        )}
      </div>

      {isFuture && (
        <div className="px-3.5 py-2.5 rounded-xl bg-zinc-950/40 border border-zinc-900/60 text-zinc-500 text-xs text-center font-medium select-none">
          Data Integrity Lock: Future logging is disabled.
        </div>
      )}

      <div className="space-y-3">
        {allHabits.map((habit) => {
          const isCompleted = !!selectedDayData[habit.id];
          const isCustom = habit.id.startsWith('custom_');

          const itemClass = isFuture
            ? 'opacity-20 bg-zinc-950/20 border-zinc-900/50 cursor-not-allowed'
            : isCompleted
            ? 'bg-emerald-500/5 border-emerald-500/30 text-zinc-100'
            : 'bg-zinc-900/40 border-zinc-800/60 text-zinc-400 hover:border-zinc-700';

          const buttonClass = isFuture
            ? 'cursor-not-allowed flex items-center gap-3.5 flex-1 text-left'
            : 'cursor-pointer flex items-center gap-3.5 flex-1 text-left';

          return (
            <div
              key={habit.id}
              className={`group flex items-center justify-between p-3.5 rounded-xl border transition-all duration-200 ${itemClass}`}
            >
              <button
                onClick={() => !isFuture && toggleHabit(habit.id)}
                disabled={isFuture}
                className={buttonClass}
              >
                <div
                  className={`w-5 h-5 rounded-lg border flex items-center justify-center transition-all ${
                    isFuture
                      ? 'border-zinc-800 text-zinc-700 bg-zinc-950/30'
                      : isCompleted
                      ? 'bg-emerald-500 border-emerald-400 text-zinc-950'
                      : 'border-zinc-700 group-hover:border-zinc-500'
                  }`}
                >
                  {isCompleted && <Check className="w-3.5 h-3.5 stroke-[3]" />}
                </div>
                <span className={`text-sm font-medium transition-all ${isFuture ? 'text-zinc-600' : isCompleted ? 'text-zinc-400 line-through opacity-80' : 'text-zinc-200'}`}>
                  {habit.label}
                </span>
              </button>

              {isCustom && !isFuture && (
                <button
                  onClick={() => removeCustomHabit(habit.id)}
                  className="p-1 text-zinc-500 hover:text-red-400 hover:bg-red-500/10 rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-150 cursor-pointer"
                  title="Remove Custom Habit"
                >
                  <Trash2 className="w-4 h-4" />
                </button>
              )}
            </div>
          );
        })}

        {allHabits.length === 0 && (
          <p className="text-sm text-zinc-500 text-center py-4">No habits set up yet.</p>
        )}
      </div>

      <form onSubmit={(e) => { e.preventDefault(); if (!isFuture) addCustomHabit(e); }} className={`flex gap-2 pt-2 border-t border-zinc-800/60 ${isFuture ? 'opacity-20 cursor-not-allowed' : ''}`}>
        <input
          type="text"
          value={customHabitInput}
          onChange={(e) => !isFuture && setCustomHabitInput(e.target.value)}
          disabled={isFuture}
          placeholder={isFuture ? "Locked..." : "Create custom habit..."}
          className={`flex-1 bg-zinc-900/60 border border-zinc-800/80 rounded-xl px-3.5 py-2 text-sm text-zinc-200 placeholder-zinc-500 focus:outline-none focus:border-emerald-500/50 transition ${isFuture ? 'cursor-not-allowed' : ''}`}
        />
        <button
          type="submit"
          disabled={isFuture}
          className={`p-2.5 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold rounded-xl transition shadow-lg shadow-emerald-500/10 flex items-center justify-center ${isFuture ? 'cursor-not-allowed bg-emerald-950/20 text-zinc-700 shadow-none border border-zinc-900' : 'cursor-pointer'}`}
        >
          <Plus className="w-4 h-4 stroke-[2.5]" />
        </button>
      </form>
    </div>
  );
}
