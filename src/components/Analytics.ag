import { AreaChart, Area, XAxis, YAxis, Tooltip, ResponsiveContainer, CartesianGrid } from 'recharts';
import { BarChart3 } from 'lucide-react';

export default function Analytics({ chartData, theme }) {
  let accentColor = '#10b981'; // Default emerald
  if (theme === 'purple') {
    accentColor = '#a855f7';
  } else if (theme === 'blue') {
    accentColor = '#3b82f6';
  }

  return (
    <div className="bg-zinc-900/30 border border-zinc-800/80 rounded-2xl p-6 backdrop-blur-md">
      <div className="flex items-center gap-2.5 mb-6">
        <BarChart3 className={`w-4 h-4 ${theme === 'purple' ? 'text-purple-400' : theme === 'blue' ? 'text-blue-400' : 'text-emerald-400'}`}/>
        <h2 className="text-sm font-semibold text-zinc-200">30-Day Progress Velocity</h2>
      </div>
      <div className="h-56 w-full">
        <ResponsiveContainer height="100%" width="100%">
          <AreaChart data={chartData} margin={{ top: 10, right: 5, left: -25, bottom: 0 }}>
            <defs>
              <linearGradient id="antigravityGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="5%" stopColor={accentColor} stopOpacity={0.15}/>
                <stop offset="95%" stopColor={accentColor} stopOpacity={0}/>
              </linearGradient>
            </defs>
            <CartesianGrid stroke="#18181b" strokeDasharray="3 3" vertical={false}/>
            <XAxis axisLine={false} dataKey="date" fontSize={10} stroke="#52525b" tickLine={false}/>
            <YAxis axisLine={false} domain={[0, 100]} fontSize={10} stroke="#52525b" tickLine={false} unit="%"/>
            <Tooltip
              contentStyle={{
                backgroundColor: '#18181b',
                borderColor: '#27272a',
                borderRadius: '12px',
                color: '#f4f4f5',
                fontSize: '11px',
              }}
            />
            <Area dataKey="Completion" fill="url(#antigravityGrad)" fillOpacity={1} stroke={accentColor} strokeWidth={2} type="monotone"/>
          </AreaChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}
